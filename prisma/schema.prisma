model exams {
  Id_esame           Int       @id @default(autoincrement()) @map("id_esame")
  Materia            String?   @map("materia") @db.VarChar(255)
  CFU                Decimal?  @map("cfu") @db.Decimal(4, 1)
  Voto               Decimal?  @map("voto") @db.Decimal(4, 1)
  Data1              DateTime? @map("data1") @db.Date
  Data2              DateTime? @map("data2") @db.Date
  Data3              DateTime? @map("data3") @db.Date
  Data4              DateTime? @map("data4") @db.Date
  Data5              DateTime? @map("data5") @db.Date
  Scelta             String?   @map("scelta") @db.Char(1)
  Anno_universitario String?   @map("anno_universitario") @db.VarChar(15)
  Id_utente          Int?      @map("id_utente")
}

model utenti {
  Id_utente        Int      @id @default(autoincrement()) @map("id_utente")
  Nome             String   @map("nome") @db.VarChar(255)
  Cognome          String   @map("cognome") @db.VarChar(255)
  Data_nascita     DateTime @map("data_nascita") @db.Date
  Ultimo_accesso   DateTime @map("ultimo_accesso") @db.Timestamp(6)
  username         String   @db.VarChar(255)
  password         String   @db.VarChar(255)
  permessi         String   @db.Char(1)
  tentativiAccesso Int?     @map("tentativiaccesso")
  bloccato         String?  @db.Char(1)
  Email            String?  @map("email") @db.VarChar(255)
  token            String?  @db.VarChar(8)
}

model eventi {
  Id_evento   Int       @id @default(autoincrement()) @map("id_evento")
  Evento      String?   @map("evento") @db.VarChar(255)
  Descrizione String?   @map("descrizione") @db.VarChar(255)
  Data        DateTime? @map("data") @db.Timestamp(6)
  Categoria   String?   @map("categoria") @db.VarChar(255)
  Id_utente   Int?      @map("id_utente")
}
