model Exams{
  Id_esame Int @id @default(autoincrement())
  Materia String?
  CFU Float?
  Voto Float?
  Data1 DateTime?
  Data2 DateTime?
  Data3 DateTime?
  Data4 DateTime?
  Data5 DateTime?
  Scelta String?
  Id_utente Int?
}

model Utenti {
  Id_utente        Int     @id @default(autoincrement())
  Nome             String
  Cognome          String
  Data_nascita     DateTime
  Ultimo_accesso   DateTime
  username         String
  password         String
  permessi         String
  tentativiAccesso Int?
  bloccato         String?
  Email            String?
  token            String?
}